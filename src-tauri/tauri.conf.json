{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi",
  "version": "0.1.0",
  "identifier": "dev.litwein.piapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pi",
        "width": 1360,
        "height": 860,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
