{
  "name": "pi-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "patch:pi-subagents": "node scripts/patch-pi-subagents-worktree.mjs",
    "check:pi-subagents": "node scripts/patch-pi-subagents-worktree.mjs --check",
    "verify:harness:final": "node bench/verify-final.mjs",
    "verify:harness:readiness": "node bench/verify-readiness.mjs",
    "tauri": "tauri",
    "bootstrap": "npm ci && npm run tauri build && node scripts/install-app.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "dompurify": "^3",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.23.0",
    "marked": "^15",
    "react": "^19",
    "react-dom": "^19",
    "react-virtuoso": "^4.18.10",
    "shiki": "^3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "~5.8",
    "vite": "^6",
    "vitest": "^3"
  }
}
